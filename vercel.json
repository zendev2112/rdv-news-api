{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/test?section=horoscopo&limit=5",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/test?section=efemerides&limit=5",
      "schedule": "7 10 * * *"
    },
    {
      "path": "/api/cron/test?section=quiniela&limit=5",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/test?section=quiniela&limit=5",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/review",
      "schedule": "0 * * * *"
    }
  ],
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/templates/**", "src/assets/**"],
        "maxDuration": 300
      }
    },
    {
      "src": "api/cron/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300,
        "includeFiles": ["src/**"]
      }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/admin",
      "dest": "/public/admin.html"
    },
    {
      "src": "/api/cron/test",
      "dest": "/api/cron/test.js"
    },
    {
      "src": "/api/cron/high",
      "dest": "/api/cron/high.js"
    },
    {
      "src": "/api/cron/medium",
      "dest": "/api/cron/medium.js"
    },
    {
      "src": "/api/cron/low",
      "dest": "/api/cron/low.js"
    },
    {
      "src": "/api/cron/review",
      "dest": "/api/cron/review.js"
    },
    {
      "src": "/api/fetch/all",
      "dest": "/api/fetch/all.js"
    },
    {
      "src": "/api/frontend/coverage",
      "dest": "/api/frontend/coverage.js"
    },
    {
      "src": "/api/agent/curate",
      "dest": "/api/agent/curate.js"
    },
    {
      "src": "/api/agent/publish",
      "dest": "/api/agent/publish.js"
    },
    {
      "src": "/api/fetch/section",
      "dest": "/api/fetch/section.js"
    },
    {
      "src": "/api/slack/process",
      "dest": "/api/slack/process.js"
    },
    {
      "src": "/api/social/process",
      "dest": "/api/social/process.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}
