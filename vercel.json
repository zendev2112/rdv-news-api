  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/templates/**", "src/assets/**"],
        "maxDuration": 300
      }
    },
    {
      "src": "api/cron/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/admin",
      "dest": "/public/admin.html"
    },
    {
      "src": "/api/cron/test",
      "dest": "/api/cron/test.js"
    },
    {
      "src": "/api/cron/high",
      "dest": "/api/cron/high.js"
    },
    {
      "src": "/api/cron/medium",
      "dest": "/api/cron/medium.js"
    },
    {
      "src": "/api/cron/low",
      "dest": "/api/cron/low.js"
    },
    {
      "src": "/api/fetch/all",
      "dest": "/api/fetch/all.js"
    },
    {
      "src": "/api/fetch/section",
      "dest": "/api/fetch/section.js"
    },
    {
      "src": "/api/slack/process",
      "dest": "/api/slack/process.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
