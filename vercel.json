{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/test?section=primera-plana&limit=10",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/test?section=instituciones&limit=10",
      "schedule": "7 8 * * *"
    },
    {
      "path": "/api/cron/test?section=local&limit=10",
      "schedule": "14 8 * * *"
    },
    {
      "path": "/api/cron/test?section=local-facebook&limit=10",
      "schedule": "21 8 * * *"
    },
    {
      "path": "/api/cron/test?section=huanguelen&limit=10",
      "schedule": "28 8 * * *"
    },
    {
      "path": "/api/cron/test?section=pueblos-alemanes&limit=10",
      "schedule": "35 8 * * *"
    },
    {
      "path": "/api/cron/test?section=la-sexta&limit=10",
      "schedule": "42 8 * * *"
    },

    {
      "path": "/api/cron/test?section=primera-plana&limit=10",
      "schedule": "0 21 * * 1-5"
    },
    {
      "path": "/api/cron/test?section=instituciones&limit=10",
      "schedule": "7 21 * * 1-5"
    },
    {
      "path": "/api/cron/test?section=local&limit=10",
      "schedule": "14 21 * * 1-5"
    },
    {
      "path": "/api/cron/test?section=local-facebook&limit=10",
      "schedule": "21 21 * * 1-5"
    },
    {
      "path": "/api/cron/test?section=huanguelen&limit=10",
      "schedule": "28 21 * * 1-5"
    },
    {
      "path": "/api/cron/test?section=pueblos-alemanes&limit=10",
      "schedule": "35 21 * * 1-5"
    },
    {
      "path": "/api/cron/test?section=la-sexta&limit=10",
      "schedule": "42 21 * * 1-5"
    },

    {
      "path": "/api/cron/test?section=horoscopo&limit=5",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/test?section=efemerides&limit=5",
      "schedule": "7 10 * * *"
    },
    {
      "path": "/api/cron/test?section=clima&limit=5",
      "schedule": "14 10 * * *"
    },
    {
      "path": "/api/cron/test?section=quiniela&limit=5",
      "schedule": "35 11 * * 1-5"
    },

    {
      "path": "/api/cron/test?section=economia&limit=10",
      "schedule": "49 8 * * 1-5"
    }
  ],
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/templates/**", "src/assets/**"],
        "maxDuration": 300
      }
    },
    {
      "src": "api/cron/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/admin",
      "dest": "/public/admin.html"
    },
    {
      "src": "/api/cron/test",
      "dest": "/api/cron/test.js"
    },
    {
      "src": "/api/cron/high",
      "dest": "/api/cron/high.js"
    },
    {
      "src": "/api/cron/medium",
      "dest": "/api/cron/medium.js"
    },
    {
      "src": "/api/cron/low",
      "dest": "/api/cron/low.js"
    },
    {
      "src": "/api/fetch/all",
      "dest": "/api/fetch/all.js"
    },
    {
      "src": "/api/fetch/section",
      "dest": "/api/fetch/section.js"
    },
    {
      "src": "/api/slack/process",
      "dest": "/api/slack/process.js"
    },
    {
      "src": "/api/social/process",
      "dest": "/api/social/process.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}
